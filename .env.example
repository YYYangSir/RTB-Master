# Copy this file to .env for local development only.
# Never commit the real .env file.

NODE_ENV=development
API_PORT=3000
ADMIN_WEB_PORT=5173
USER_WEB_PORT=5174

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=auction
MYSQL_USER=auction
MYSQL_PASSWORD=local-development-only
MYSQL_ROOT_PASSWORD=local-root-development-only
DATABASE_URL=mysql://auction:local-development-only@127.0.0.1:3306/auction
SHADOW_DATABASE_URL=mysql://auction:local-development-only@127.0.0.1:3306/auction_shadow

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

# Replace in local .env before implementing authentication.
JWT_SECRET=replace-with-local-secret
